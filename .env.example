# Database used by backend and sweep worker.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tonhub_payments?schema=public"

# Public API defaults.
TONHUB_PAYMENTS_PORT=3008
TONHUB_CORS_ORIGIN="http://localhost:5173"
TON_DEFAULT_NETWORK=testnet
TON_ALLOWED_NETWORKS=testnet,mainnet
TON_INVOICE_REFERENCE_PREFIX=TONHUB
TON_INVOICE_TTL_MINUTES=60
TON_PARTIAL_PAYMENT_TTL_HOURS=24

# TON Center API keys. Testnet and mainnet can use separate keys.
TON_TESTNET_API_KEY=
TON_MAINNET_API_KEY=

# Public keys used by the backend to derive one V5R1 deposit wallet per invoice.
# Use the matching secret keys only in the worker environment, not in web/API.
TON_TESTNET_DEPOSIT_PUBLIC_KEY=
TON_MAINNET_DEPOSIT_PUBLIC_KEY=
TON_DEPOSIT_WALLET_WORKCHAIN=0

# Worker-only signing credentials for sweeping paid deposit wallets.
TON_TESTNET_DEPOSIT_SECRET_KEY=
TON_MAINNET_DEPOSIT_SECRET_KEY=
TON_TESTNET_SWEEP_RECIPIENT_ADDRESS=
TON_MAINNET_SWEEP_RECIPIENT_ADDRESS=
TON_SWEEP_RESERVE_NANO=50000000
TON_SWEEP_MIN_NANO=1000000
TON_SWEEP_NETWORK=testnet

# Frontend demo defaults.
VITE_TONHUB_PAYMENTS_API_BASE="/api/tonhub-payments"
VITE_TONHUB_PAYMENTS_DEFAULT_NETWORK=testnet

